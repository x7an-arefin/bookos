{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "target": "es2022",
    "customConditions": ["@bookos-temp/source"],
    "baseUrl": ".",
    "paths": {
      "@bookos/electron-api-types": ["./apps/electron/src/shared/electron-api.types.ts"],
      "@press/core": ["./libs/core/src/index.ts"]
    }
  }
}

